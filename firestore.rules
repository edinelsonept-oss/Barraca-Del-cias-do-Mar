rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasRole(role) { return isSignedIn() && getUserData().role == role; }
    function isAdmin() { return hasRole('admin'); }
    function isWaiter() { return hasRole('waiter'); }
    function isCustomer() { return hasRole('customer'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Rules ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isWaiter());
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && 
                    incoming().keys().hasAll(['uid', 'email', 'role', 'name']) && 
                    incoming().role in ['waiter', 'customer', 'admin'];
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'active', 'role']));
      allow delete: if isAdmin();
    }

    // --- Menu Rules ---
    match /menuItems/{itemId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // --- Table Rules ---
    match /tables/{tableId} {
      allow read: if isWaiter() || isAdmin() || (isCustomer() && existing().customerId == request.auth.uid);
      allow create: if isWaiter() || isAdmin();
      allow update: if isWaiter() || isAdmin() || (isCustomer() && existing().customerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'customerId', 'totalAmount', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // --- Order Rules ---
    match /orders/{orderId} {
      allow read: if isWaiter() || isAdmin() || (isCustomer() && existing().customerId == request.auth.uid);
      allow create: if isWaiter() || isAdmin() || isCustomer();
      allow update: if isWaiter() || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Notification Rules ---
    match /notifications/{notificationId} {
      allow read: if isWaiter() || isAdmin();
      allow create: if isCustomer() || isWaiter() || isAdmin();
      allow update: if isWaiter() || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Invitation Rules ---
    match /waiter_invitations/{email} {
      allow read: if true; // Needed during registration check
      allow write: if isAdmin();
    }

    // --- Review Rules ---
    match /reviews/{reviewId} {
      allow read: if true; // Everyone can see reviews
      allow create: if isSignedIn() && isCustomer() && 
                    incoming().customerId == request.auth.uid &&
                    incoming().rating >= 1 && incoming().rating <= 5 &&
                    incoming().comment is string && incoming().comment.size() <= 1000;
      allow update, delete: if isAdmin();
    }
  }
}
